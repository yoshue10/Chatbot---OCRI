# WhatsApp Bot UNCP - Variables de Entorno

# Prefijo del bot (opcional, por defecto "UNCP-BOT")
BOT_PREFIX=UNCP-BOT

# Tiempo de simulación humana (milisegundos)
TYPING_MIN_DELAY=2000
TYPING_MAX_DELAY=3000
FILE_DELAY=2000

# Persistencia de sesiones
SESSION_FILE=./data/sessions.json

# Número de teléfono del administrador (para notificaciones)
ADMIN_PHONE=51999999999

# Token para Telegram (opcional)
TELEGRAM_BOT_TOKEN=

# Chat ID de Telegram para notificaciones (opcional)
TELEGRAM_CHAT_ID=

# Configuración SMTP para correo (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TO=

# Nivel de log: debug, info, warn, error
LOG_LEVEL=info
